# GitHub REST API v3 token — classic PAT, public-repo read scope only. Server-side only, never exposed to the client. REQUIRED.
GITHUB_TOKEN=

# Anthropic API key for autopsy synthesis and the ghost chat. Server-side only. REQUIRED.
ANTHROPIC_API_KEY=

# Upstash Redis REST URL — Dossier/autopsy cache and chat rate-limit store. OPTIONAL: omit for local dev to use the in-memory LRU fallback.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token — pairs with UPSTASH_REDIS_REST_URL. OPTIONAL: omit for the in-memory LRU fallback.
UPSTASH_REDIS_REST_TOKEN=
